{
  "listen_host": "127.0.0.1",
  "port": 8787,
  "backend": "onnxruntime",
  "runtime_root": "runtimes/linux-x64",
  "model_manifest": "models/ppocrv6-tiny/model.json",
  "web_root": "www",
  "device_id": 0,
