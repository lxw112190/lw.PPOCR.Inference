[Unit]
Description=lw.PPOCR OpenCV DNN HTTP OCR service
After=network.target

[Service]
Type=simple
DynamicUser=yes
WorkingDirectory=/opt/lw-ppocr
ExecStart=/opt/lw-ppocr/run-http-service.sh
Restart=on-failure
RestartSec=3
NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=yes
ProtectSystem=strict

[Install]
WantedBy=multi-user.target
