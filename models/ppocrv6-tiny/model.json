{
  "$schema": "../model-manifest.schema.json",
  "schema_version": 1,
  "name": "PP-OCRv6 tiny Chinese",
  "family": "PP-OCRv6",
  "language": "ch",
  "dictionary": {
    "path": "ppocr_keys.txt"
  },
  "stages": {
    "detector": {
      "input_name": "x",
      "output_name": "fetch_name_0",
      "input_shape": [-1, 3, -1, -1],
      "artifacts": {
        "onnx": {
          "path": "det.onnx",
          "format": "onnx",
          "precision": "fp32"
        },
        "tensorrt": {
          "path": "det.fp16.engine",
          "format": "tensorrt-engine",
          "precision": "fp16"
        }
      }
    },
    "classifier": {
      "input_shape": [1, 3, 80, 160],
      "artifacts": {
        "onnx": {
          "path": "cls.onnx",
          "format": "onnx",
          "precision": "fp32"
        },
        "tensorrt": {
          "path": "cls.fp16.engine",
          "format": "tensorrt-engine",
          "precision": "fp16"
        }
      }
    },
    "recognizer": {
      "input_name": "x",
      "output_name": "fetch_name_0",
      "input_shape": [1, 3, 48, 320],
      "artifacts": {
        "onnx": {
          "path": "rec.onnx",
          "format": "onnx",
          "precision": "fp32"
        },
        "tensorrt": {
          "path": "rec.fp16.engine",
          "format": "tensorrt-engine",
          "precision": "fp16"
        }
      }
    }
  }
}
