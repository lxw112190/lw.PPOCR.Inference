# Host port exposed by Docker Compose.
PPOCR_HTTP_PORT=8787

# Leave empty only for trusted local testing. Set a long random value before
# exposing the service to a LAN or through a reverse proxy.
LW_PPOCR_API_KEY=

# HTTP worker threads inside the container (1-64).
LW_PPOCR_WORKER_THREADS=4

# The default image uses the formal v1.3.0 Linux x64 OpenCV DNN package.
PPOCR_PLATFORM=linux/amd64
PPOCR_VERSION=1.3.0
PPOCR_PACKAGE=lw.PPOCR.Inference-v1.3.0-linux-x64-opencv
PPOCR_SHA256=4ed127d541d0f9077a78261513801650ecd9524d69ef377c200898184398a208

